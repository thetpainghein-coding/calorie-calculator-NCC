            txtMetric3.Text = "";
        }

       
        private void HomeForm_Load(object sender, EventArgs e)
        {
            uid = GlobalData._UserId;
            aid = cboxActivity.SelectedIndex + 1;

            lblDateNum.Text = DateTime.Now.ToString();
            lblTarCal.Text = "Target Calorie: " + GlobalData._TargetCalorie.ToString();
            lblDateNum.Text = DateTime.Now.ToShortDateString();
            lblWelcome.Text = "Welcome, " + GlobalData._Username;
            lblTotalCurCal.Text = "Total Calorie Burnt: " + totalcurCal.ToString();
            

            //cboxActivity.Text = "Select One";
            //GlobalData._Date = lblDateNum.Text;  

            //Showing the activity records of the user in the datagridview
            DBClass db = new DBClass();
            dataGridView1.DataSource = db.getTable(uid, aid);
            dataGridView1.DataMember = "UserActivityMatricTable";
            //activity = lstActivities.SelectedItem.ToString();
            groupBox2.Text = "All the records of " + activity;
           

            //Showing all the activities from database in combobox
            List<string> lst = new List<string>();
            lst = db.getActivities();
            cboxActivity.DataSource = lst;
            cboxActivity.Show();
        }

        
    }
